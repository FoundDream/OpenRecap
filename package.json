{
  "name": "openrecap",
  "version": "0.1.0",
  "description": "Review your daily Claude Code sessions and generate visual learning reports",
  "type": "module",
  "bin": {
    "openrecap": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "ai": "^6.0",
    "@ai-sdk/amazon-bedrock": "^4.0",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "commander": "^14.0",
    "@inquirer/prompts": "^7.0",
    "chalk": "^5.4",
    "ora": "^8.2",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "latest",
    "tsup": "^8.3",
    "typescript": "^5.7"
  },
  "engines": {
    "node": ">=18"
  }
}
